[Unit]
Description=FashionEcommerce Admin Panel
After=network.target fashion-backend.service

[Service]
Type=simple
WorkingDirectory=/opt/fashion-ecommerce
EnvironmentFile=/opt/fashion-ecommerce/.env
ExecStart=/usr/bin/node /opt/fashion-ecommerce/deploy/serve-admin.mjs
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
