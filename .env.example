# === FashionEcommerce 全局配置 ===
# 复制此文件为 .env 并根据环境修改
# cp .env.example .env

# --- 服务器绑定地址 ---
# 0.0.0.0 允许外部访问（ECS 部署必须），127.0.0.1 仅本机
HOST=0.0.0.0

# --- 后端 API 服务 ---
# BACKEND_HOST: 后端监听的主机名（本地部署用 localhost）
# BACKEND_PORT: 后端监听端口
BACKEND_HOST=localhost
BACKEND_PORT=3001

# --- H5 前端静态服务 ---
H5_PORT=8080

# --- 管理后台 ---
ADMIN_PORT=8081
ADMIN_DEV_PORT=5173

# --- 股东门户 ---
SHAREHOLDER_PORT=8082
SHAREHOLDER_BACKEND_PORT=8083

# --- Playwright 测试 ---
PLAYWRIGHT_PORT=3002

# =============================================
# 阿里云 ECS 部署注意事项:
# =============================================
# 1. 安全组需开放以上端口（3001, 8080, 8081）
# 2. HOST 保持 0.0.0.0 以允许外部访问
# 3. BACKEND_HOST 保持 localhost（服务在同一机器）
# 4. 部署命令: ./deploy/deploy-remote.sh
# 5. systemd 自启: sudo bash deploy/setup-systemd.sh
