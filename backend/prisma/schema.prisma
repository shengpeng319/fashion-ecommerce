generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 管理员体系 ============

model AdminUser {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  nickname  String
  role      String   @default("admin") // admin, super_admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ 用户体系 ============

model User {
  id         String   @id @default(uuid())
  phone      String   @unique
  password   String
  nickname   String?
  avatar     String?
  gender     String   @default("unknown")
  referrerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  addresses    Address[]
  member       Member?
  cartItems    CartItem[]
  orders       Order[]
  dealer       Dealer?
  shareholder  Shareholder?
  referrer     User?    @relation("ReferralRelation", fields: [referrerId], references: [id])
  referrals    User[]   @relation("ReferralRelation")
}

// ============ 收货地址 ============

model Address {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String
  province  String
  city      String
  district  String
  detail    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  Order Order[]
}

// ============ 会员体系 ============

model Member {
  id            String   @id @default(uuid())
  userId        String   @unique
  level         String   @default("LIGHT")
  points        Int      @default(0)
  totalSpent    Decimal  @db.Decimal(10,2) @default(0)
  depositAmount Decimal  @db.Decimal(10,2) @default(0)
  birthday      String?
  joinedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PointsTransaction[]
}

model MembershipLevel {
  id           String  @id @default(uuid())
  name         String  // 等级中文名
  key          String  @unique // LIGHT/PREMIUM/LUXURY/SELECT/CREATOR/OFFICER
  minDeposit   Int     // 入会门槛金额(元)
  bonusPoints  Int     // 到账积分
  isRefundable Boolean // 预存款是否可退
  sortOrder    Int     // 排序
  benefits     String? @db.Text // JSON格式权益描述
}

model PointsTransaction {
  id          String   @id @default(uuid())
  memberId    String
  type        String   // EARN/REDEEM/REFUND/REFERRAL/GIFT
  amount      Int      // 正数为获得，负数为消耗
  balance     Int      // 变化后余额
  description String
  orderId     String?
  createdAt   DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Referral {
  id             String    @id @default(uuid())
  referrerUserId String
  referredUserId String
  pointsAwarded  Int       @default(0)
  status         String    @default("PENDING") // PENDING/COMPLETED
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
}

// ============ 商品体系 ============

model Category {
  id        String    @id @default(uuid())
  name      String
  icon      String?
  sort      Int       @default(0)
  parentId  String?
  products  Product[]
  createdAt DateTime  @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  logo      String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            String   @id @default(uuid())
  name          String
  subtitle      String?
  price         Decimal  @db.Decimal(10,2)
  originalPrice Decimal? @db.Decimal(10,2)
  image         String?  // 主图
  thumbnail     String?  // 缩略图
  images        String?  @db.Text // 多图JSON
  description   String?  @db.Text
  detail        String?  @db.LongText
  categoryId    String
  brandId       String?
  sales         Int      @default(0)
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id])
  brand             Brand?             @relation(fields: [brandId], references: [id])
  skus              SKU[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  wholesaleProducts WholesaleProduct[]
}

model SKU {
  id         String   @id @default(uuid())
  productId  String
  name       String
  price      Decimal  @db.Decimal(10,2)
  stock      Int      @default(0)
  attributes String
  createdAt  DateTime @default(now())

  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  CartItem  CartItem[]
  OrderItem OrderItem[]
}

// ============ 购物车 ============

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  skuId     String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku     SKU?    @relation(fields: [skuId], references: [id])

  @@unique([userId, productId, skuId])
}

// ============ 订单体系 ============

model Order {
  id             String    @id @default(uuid())
  orderNo        String    @unique
  userId         String
  status         String
  totalAmount    Decimal  @db.Decimal(10,2)
  discountAmount Decimal  @db.Decimal(10,2) @default(0)
  pointsUsed     Int      @default(0)
  payAmount      Decimal  @db.Decimal(10,2)
  payType        String?
  payTime        DateTime?
  addressId      String
  remark         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  skuId       String?
  productName String
  skuName     String?
  price       Decimal @db.Decimal(10,2)
  quantity    Int
  image       String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  sku     SKU?    @relation(fields: [skuId], references: [id])
}

// ============ B端批发 ============

model Dealer {
  id          String   @id @default(uuid())
  userId      String   @unique
  companyName String
  licenseNo   String
  level       String
  creditLine  Decimal  @db.Decimal(10,2) @default(0)
  usedCredit  Decimal  @db.Decimal(10,2) @default(0)
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  wholesaleOrders WholesaleOrder[]
}

model WholesaleProduct {
  id          String   @id @default(uuid())
  productId   String
  dealerPrice Decimal @db.Decimal(10,2)
  minQty      Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model WholesaleOrder {
  id          String   @id @default(uuid())
  orderNo     String   @unique
  dealerId    String
  status      String
  totalAmount Decimal @db.Decimal(10,2)
  payAmount   Decimal @db.Decimal(10,2)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dealer Dealer @relation(fields: [dealerId], references: [id])
}

// ============ 股东合伙体系 ============

model ShareholderLevelConfig {
  id        String   @id @default(uuid())
  level     Int      @unique  // 1=普通股东, 2=战略股东, 3=创始人股东
  name      String            // 级别名称
  minAmount Decimal  @db.Decimal(10,2) // 门槛金额
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shareholder {
  id        String   @id @default(uuid())
  userId    String   @unique
  level     Int      @default(1)  // 股东级别
  name      String
  phone     String
  status    String   @default("active")  // active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  investments ShareholderInvestment[]
  dividends   ShareholderDividend[]
  costs       ShareholderCost[]
}

model ShareholderInvestment {
  id            String   @id @default(uuid())
  shareholderId String
  amount        Decimal  @db.Decimal(10,2)
  type          String   // initial=初始投资, additional=追加投资, withdrawal=撤回
  remark        String?
  createdAt     DateTime @default(now())

  shareholder Shareholder @relation(fields: [shareholderId], references: [id], onDelete: Cascade)
}

model ShareholderDividend {
  id            String   @id @default(uuid())
  shareholderId String
  amount        Decimal  @db.Decimal(10,2)
  period        String   // 分红周期，如 "2024Q1"
  status        String   @default("pending")  // pending=待发放, paid=已发放
  createdAt     DateTime @default(now())

  shareholder Shareholder @relation(fields: [shareholderId], references: [id], onDelete: Cascade)
}

model ShareholderCost {
  id            String   @id @default(uuid())
  shareholderId String
  amount        Decimal  @db.Decimal(10,2)
  type          String   // platform=平台费用, marketing=营销费用, operation=运营费用
  remark        String?
  period        String   // 周期，如 "2024Q1"
  createdAt     DateTime @default(now())

  shareholder Shareholder @relation(fields: [shareholderId], references: [id], onDelete: Cascade)
}
